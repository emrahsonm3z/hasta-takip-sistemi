{
  "name": "hasta-takip-sistemi",
  "description": "Bilingual (TR/EN) patient tracking panel — React 18 + PrimeReact case study",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emrahsonm3z/hasta-takip-sistemi.git"
  },
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc -b",
    "lint": "eslint .",
    "lint:style": "stylelint \"src/**/*.scss\" --allow-empty-input",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run type-check && npm run lint && npm run lint:style && npm run format:check",
    "test": "node --test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,html}": [
      "prettier --write"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/react": "^10.58.0",
    "@tanstack/react-query": "^5.101.0",
    "dayjs": "^1.11.21",
    "formik": "^2.4.9",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.1",
    "primeicons": "7.0.0",
    "primereact": "10.9.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "tailwindcss": "3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}
